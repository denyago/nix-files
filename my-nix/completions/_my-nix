#compdef my-nix

_my_nix() {
  local -a commands
  commands=(
    'apply:Apply nix-darwin configuration'
    'commit:Commit and push changes across all repos'
    'upgrade:Upgrade nix and Homebrew packages'
    'do-release-upgrade:Bump to the latest release train'
    'cleanup:Clean up nix generations and store'
  )

  _arguments -C \
    '1:command:->cmds' && return 0

  case $state in
    cmds)
      _describe 'command' commands
      ;;
  esac
}

_my_nix "$@"
